{
  "name": "calculator-project",
  "version": "1.0.0",
  "description": "JS Web Calculator MVP",
  "type": "module",
  "scripts": {
    "test:unit": "vitest run tests/unit",
    "test:unit:coverage": "vitest run tests/unit --coverage --coverage.reporter=text --coverage.reporter=html",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "serve": "^14.2.5",
    "vitest": "^4.0.18"
  }
}
